DATA_DIR=.data
OUTPUT_DIR=outputs/daily
SYNC_MAX_PAGES_PER_SOURCE=2

# Optional X bookmarks source.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:17863/callback

# Optional AI summary. If SUMMARY_API_KEY is empty, sync still works.
SUMMARY_API_KEY=
SUMMARY_MODEL=gpt-4.1-mini
SUMMARY_BASE_URL=https://api.openai.com/v1/responses

# Optional GitHub starred repositories source.
GITHUB_TOKEN=

# Optional Cloudflare admin endpoints protection.
ADMIN_SECRET=
POSTGRES_URL=
